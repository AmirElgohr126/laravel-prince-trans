{
  "name": "prince/trans",
  "description": "A professional UI-based migration builder for Laravel Translatable package",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Your Name",
      "email": "you@example.com"
    }
  ],
  "require": {
    "php": "^8.1",
    "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
    "livewire/livewire": "^3.0"
  },
  "suggest": {
    "astrotomic/laravel-translatable": "Install this to use generated models with the Translatable trait."
  },
  "autoload": {
    "psr-4": {
      "Astrotomic\\TranslatableMigrationBuilder\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Astrotomic\\TranslatableMigrationBuilder\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Astrotomic\\TranslatableMigrationBuilder\\TranslatableMigrationBuilderServiceProvider"
      ]
    }
  }
}
