{
    "name": "elgohr/laravel-trans-builder",
    "description": "A professional UI-based migration builder for Laravel Translatable package",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Amir Nagy",
            "email": "amirnagy886@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0",
        "livewire/livewire": "^3.0"
    },
    "suggest": {
        "astrotomic/laravel-translatable": "Install this to use generated models with the Translatable trait."
    },
    "autoload": {
        "psr-4": {
            "Elgohr\\Trans\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Elgohr\\Trans\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Elgohr\\Trans\\TranslatableMigrationBuilderServiceProvider"
            ]
        }
    }
}
